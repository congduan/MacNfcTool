{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MacNfcTool",
  "version": "0.1.0",
  "identifier": "com.congduan.macnfctool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mac NFC Tool",
        "width": 1120,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
